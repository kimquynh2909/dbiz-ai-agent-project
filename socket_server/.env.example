# Socket.IO Server Configuration

# Environment (development/production)
NODE_ENV=production

# Server Port
SIO_PORT=7000

# CORS Origins (comma-separated for multiple domains)
# REQUIRED in production - NEVER use "*" in production!
# Examples:
#   Single domain: https://your-domain.com
#   Multiple: https://domain1.com,https://domain2.com
#   With subdomain: https://*.your-domain.com
SIO_CORS=https://your-domain.com

# Authentication Token
# REQUIRED for production security
# Generate strong token: openssl rand -hex 32
SIO_AUTH_TOKEN=dbiz_socketio_secure_token_01234567890

# Connection Limits
SIO_MAX_CONNECTIONS=1000

# Rate Limiting (per socket)
SIO_RATE_LIMIT_WINDOW=60000  # milliseconds (60s)
SIO_RATE_LIMIT_MAX=100        # max events per window

# WebSocket Timeouts
SIO_PING_TIMEOUT=20000   # milliseconds
SIO_PING_INTERVAL=25000  # milliseconds
